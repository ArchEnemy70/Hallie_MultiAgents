<Window x:Class="Hallie.Views.FeedBack"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hallie.Views"        
        mc:Ignorable="d"
        Title="Feed Back" MinHeight="420" MinWidth="820" Height="420" Width="820" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Chaîne complète" FontWeight="Bold" Margin="0,0,0,6"/>
            <Border Padding="8" BorderBrush="#33000000" BorderThickness="1" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="{Binding FeedbackChainDisplay}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Text="Ce feedback enregistre une ligne pour la chaîne complète, puis une ligne par outil exécuté." Margin="0,4,0,0" Foreground="Gray" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,12">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding FeedbackItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" Margin="0,0,0,8" BorderBrush="#22000000" BorderThickness="1" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding ToolName}"/>

                                    <ComboBox Grid.Column="1"
                                              Margin="8,0,8,0"
                                              SelectedValuePath="Tag"
                                              SelectedValue="{Binding OutcomeMode, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding DataContext.IsFeedbackNegatif, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <ComboBoxItem Content="OK" Tag="positive"/>
                                        <ComboBoxItem Content="KO" Tag="negative"/>
                                        <ComboBoxItem Content="Ignorer" Tag="skip"/>
                                    </ComboBox>

                                    <ComboBox Grid.Column="2"
                                          Margin="0,0,8,0"
                                          ItemsSource="{Binding DataContext.ExpectedToolOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding SelectedExpectedTool, UpdateSourceTrigger=PropertyChanged}"
                                          Visibility="{Binding DataContext.IsFeedbackNegatif, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>

                                    <ComboBox Grid.Column="3"
                                          Margin="0,0,8,0"
                                          ItemsSource="{Binding DataContext.ErrorClassOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding SelectedErrorClass, UpdateSourceTrigger=PropertyChanged}"
                                          Visibility="{Binding DataContext.IsFeedbackNegatif, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>

                                    <TextBox Grid.Column="4"
                                             Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Commentaire optionnel pour cet outil"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Commentaire global" FontWeight="Bold" Margin="0,4,0,6"/>
                <TextBox Height="60"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Text="{Binding FeedbackComment, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Commentaire optionnel sur la chaîne complète"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Margin="5" Click="Ok_Click"/>
            <Button Content="Annuler" Width="70" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
