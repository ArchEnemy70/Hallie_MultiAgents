<Window x:Class="Hallie.Views.ParametresPrompts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hallie.Views"
        mc:Ignorable="d"
                Title="Prompts Raccourcis" MinHeight="450" Height="450" MinWidth="900" Width="900"  Background="#FFF0F0F0">
    <Grid Margin="5,5,5,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*" MinHeight="150"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="IntitulePrompt" Text="{Binding IntitulePrompt}" FontWeight="Bold" Margin="0,0,0,0" Grid.Row="0"/>

        <ListBox Grid.Row="1" Margin="0,0,0,0" HorizontalAlignment="Left" Width="300" ItemsSource="{Binding ListeItems}" SelectedItem="{Binding SelectItem}" >

        </ListBox>

        <TextBox x:Name="PromptBox"  Text="{Binding Prompt, Mode=TwoWay}" TextWrapping="Wrap" AcceptsReturn="True" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="310,0,0,0"/>
        <Button Style="{DynamicResource ButtonStyle}" Content="Afficher" Click="OnSelectClick" Width="90" Margin="0,0,140,0" Height="30" Grid.Row="2" HorizontalAlignment="Left"/>
        <Button Style="{DynamicResource ButtonStyle}" Content="Créer" Click="OnCreateClick" Width="90" Margin="105,0,0,0" Height="30" Grid.Row="2" HorizontalAlignment="Left"/>
        <Button Style="{DynamicResource ButtonStyle}" Content="Copier" Click="OnCopyClick" Width="90" Margin="210,0,0,0" Height="30" Grid.Row="2" HorizontalAlignment="Left"/>

        <TextBlock x:Name="StatusText" Background="AliceBlue" Foreground="Green" Margin="5,5,5,5" Grid.Row="3"/>

        <Button Style="{DynamicResource ButtonStyle}" Content="Enregistrer" Click="OnSaveClick" Width="120" Margin="0,0,140,0" Height="30" Grid.Row="4" HorizontalAlignment="Right"/>
        <Button Style="{DynamicResource ButtonStyle}" Content="Fermer" Click="OnFermerClick" Width="120" Margin="0,0,0,0" Height="30" Grid.Row="4" HorizontalAlignment="Right"/>



    </Grid>
</Window>
